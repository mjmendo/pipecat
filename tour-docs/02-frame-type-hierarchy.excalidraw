{"type":"excalidraw","version":2,"source":"mcp-excalidraw-server","elements":[{"id":"title","type":"text","x":200,"y":-40,"strokeColor":"#1e1e1e","text":"Pipecat Frame Type Hierarchy","fontSize":28,"fontFamily":2},{"id":"frame-base","type":"rectangle","x":400,"y":40,"width":160,"height":50,"backgroundColor":"#dee2e6","strokeColor":"#495057","roughness":1,"label":{"text":"Frame"}},{"id":"frame-note","type":"text","x":570,"y":48,"strokeColor":"#868e96","text":"id, name, pts, metadata","fontSize":12,"fontFamily":3},{"id":"sys-frame","type":"rectangle","x":50,"y":150,"width":180,"height":50,"backgroundColor":"#ffc9c9","strokeColor":"#e03131","roughness":1,"label":{"text":"SystemFrame"}},{"id":"sys-note","type":"text","x":50,"y":205,"strokeColor":"#e03131","text":"Priority queue, survives interruptions\nHandled immediately","fontSize":12,"fontFamily":2},{"id":"data-frame","type":"rectangle","x":380,"y":150,"width":180,"height":50,"backgroundColor":"#a5d8ff","strokeColor":"#1971c2","roughness":1,"label":{"text":"DataFrame"}},{"id":"data-note","type":"text","x":380,"y":205,"strokeColor":"#1971c2","text":"Ordered FIFO queue\nCancelled by interruptions","fontSize":12,"fontFamily":2},{"id":"ctrl-frame","type":"rectangle","x":700,"y":150,"width":180,"height":50,"backgroundColor":"#b2f2bb","strokeColor":"#2f9e44","roughness":1,"label":{"text":"ControlFrame"}},{"id":"ctrl-note","type":"text","x":700,"y":205,"strokeColor":"#2f9e44","text":"Ordered FIFO queue\nCancelled by interruptions","fontSize":12,"fontFamily":2},{"id":"a-frame-sys","type":"arrow","x":395,"y":92,"strokeColor":"#495057","points":[[0,0],[-170,55]],"endArrowhead":"arrow","startBinding":{"elementId":"frame-base","focus":0,"gap":8},"endBinding":{"elementId":"sys-frame","focus":0,"gap":8}},{"id":"a-frame-data","type":"arrow","x":477,"y":98,"strokeColor":"#495057","points":[[0,0],[-4,44]],"endArrowhead":"arrow","startBinding":{"elementId":"frame-base","focus":0,"gap":8},"endBinding":{"elementId":"data-frame","focus":