{"type":"excalidraw","version":2,"source":"mcp-excalidraw-server","elements":[{"id":"title","type":"text","x":250,"y":0,"strokeColor":"#1e1e1e","text":"Example 2: User Interrupts the Bot Mid-Sentence","fontSize":24,"fontFamily":2},{"id":"subtitle","type":"text","x":250,"y":35,"strokeColor":"#868e96","text":"Bot is saying \"I'm a voice assistant that can help you with various tasks.\"  —  User says \"Wait, actually—\"","fontSize":13,"fontFamily":2},{"id":"h-transport","type":"rectangle","x":50,"y":80,"width":120,"height":40,"backgroundColor":"#e9ecef","strokeColor":"#495057","roughness":1},{"id":"h-transport-t","type":"text","x":62,"y":88,"strokeColor":"#495057","text":"Transport In","fontSize":13,"fontFamily":2},{"id":"h-stt","type":"rectangle","x":220,"y":80,"width":80,"height":40,"backgroundColor":"#e9ecef","strokeColor":"#495057","roughness":1},{"id":"h-stt-t","type":"text","x":243,"y":92,"strokeColor":"#495057","text":"STT","fontSize":13,"fontFamily":2},{"id":"h-vad","type":"rectangle","x":350,"y":80,"width":120,"height":40,"backgroundColor":"#ffc9c9","strokeColor":"#e03131","roughness":1},{"id":"h-vad-t2","type":"text","x":362,"y":88,"strokeColor":"#e03131","text":"User Agg\n(VAD + Turn)","fontSize":11,"fontFamily":2},{"id":"h-llm","type":"rectangle","x":520,"y":80,"width":80,"height":40,"backgroundColor":"#e9ecef","strokeColor":"#495057","roughness":1},{"id":"h-llm-t","type":"text","x":543,"y":92,"strokeColor":"#495057","text":"LLM","fontSize":13,"fontFamily":2},{"id":"h-tts","type":"rectangle","x":650,"y":80,"width":80,"height":40,"backgroundColor":"#e9ecef","strokeColor":"#495057","roughness":1},{"id":"h-tts-t","type":"text","x":673,"y":92,"strokeColor":"#495057","text":"TTS","fontSize":13,"fontFamily":2},{"id":"h-tout","type":"rectangle","x":780,"y":80,"width":130,"height":40,"backgroundColor":"#e9ecef","strokeColor":"#495057","roughness":1},{"id":"h-tout-t","type":"text","x":792,"y":88,"strokeColor":"#495057","text":"Transport Out","fontSize":13,"fontFamily":2},{"id":"h-tasksrc","type":"rectangle","x":960,"y":80,"width":120,"height":40,"backgroundColor":"#d0bfff","strokeColor":"#7048e8","roughness":1},{"id":"h-tasksrc-t","type":"text","x":978,"y":92,"strokeColor":"#7048e8","text":"TaskSource","fontSize":13,"fontFamily":2},{"id":"h-tasksink","type":"rectangle","x":1130,"y":80,"width":120,"height":40,"backgroundColor":"#d0bfff","strokeColor":"#7048e8","roughness":1},{"id":"h-tasksink-t","type":"text","x":1153,"y":92,"strokeColor":"#7048e8","text":"TaskSink","fontSize":13,"fontFamily":2},{"id":"line-transport","type":"line","x":110,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-stt","type":"line","x":260,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-vad","type":"line","x":410,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-llm","type":"line","x":560,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-tts","type":"line","x":690,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-tout","type":"line","x":845,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-tasksrc","type":"line","x":1020,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"line-tasksink","type":"line","x":1190,"y":120,"strokeColor":"#dee2e6","strokeStyle":"dashed","points":[[0,0],[0,1250]]},{"id":"phase1-bg","type":"rectangle","x":30,"y":135,"width":1240,"height":210,"backgroundColor":"#a5d8ff","strokeColor":"#1971c2","strokeStyle":"dashed","roughness":1,"opacity":12},{"id":"phase1-label","type":"text","x":40,"y":140,"strokeColor":"#1971c2","text":"BEFORE: Bot is speaking (TTS audio chunks flowing to speaker)","fontSize":14,"fontFamily":2},{"id":"a-llm-tts","type":"arrow","x":560,"y":175,"strokeColor":"#1971c2","points":[[0,0],[122,0]],"endArrowhead":"arrow"},{"id":"t-llm-tts","type":"text","x":570,"y":158,"strokeColor":"#1971c2","text":"LLMTextFrame(\"help you\")","fontSize":11,"fontFamily":3},{"id":"a-tts-tout6","type":"arrow","x":690,"y":205,"strokeColor":"#1971c2","points":[[0,0],[147,0]],"endArrowhead":"arrow"},{"id":"t-tts-tout6","type":"text","x":700,"y":188,"strokeColor":"#1971c2","text":"TTSAudioRawFrame #6","fontSize":11,"fontFamily":3},{"id":"a-tts-tout7","type":"arrow","x":690,"y":230,"strokeColor":"#1971c2","points":[[0,0],[147,0]],"endArrowhead":"arrow"},{"id":"t-tts-tout7","type":"text","x":700,"y":213,"strokeColor":"#1971c2","text":"TTSAudioRawFrame #7","fontSize":11,"fontFamily":3},{"id":"a-tts-tout8","type":"arrow","x":690,"y":255,"strokeColor":"#1971c2","points":[[0,0],[147,0]],"endArrowhead":"arrow"},{"id":"t-tts-tout8","type":"text","x":700,"y":238,"strokeColor":"#1971c2","text":"TTSAudioRawFrame #8","fontSize":11,"fontFamily":3},{"id":"t-tout-queue","type":"text","x":855,"y":270,"strokeColor":"#868e96","text":"Process Queue has\n#9 and #10 waiting","fontSize":11,"fontFamily":2},{"id":"t-llm-queue","type":"text","x":555,"y":295,"strokeColor":"#868e96","text":"Process Queue has\nmore LLMTextFrames","fontSize":11,"fontFamily":2},{"id":"phase2-bg","type":"rectangle","x":30,"y":360,"width":1240,"height":220,"backgroundColor":"#ffc9c9","strokeColor":"#e03131","strokeStyle":"dashed","roughness":1,"opacity":12},{"id":"phase2-label2","type":"text","x":40,"y":365,"strokeColor":"#e03131","text":"TRIGGER: User says \"Wait, actually—\" → User Agg's VAD detects speech → InterruptionTaskFrame goes UPSTREAM","fontSize":14,"fontFamily":2},{"id":"t-step1-v2","type":"text","x":42,"y":395,"strokeColor":"#e03131","text":"❶ User speaks — audio is already flowing as InputAudioRawFrame","fontSize":13,"fontFamily":2},{"id":"a-audio-agg","type":"arrow","x":110,"y":430,"strokeColor":"#868e96","strokeStyle":"dashed","points":[[0,0],[292,0]],"endArrowhead":"arrow"},{"id":"t-audio-agg","type":"text","x":130,"y":413,"strokeColor":"#868e96","text":"InputAudioRawFrame (downstream through pipeline)","fontSize":10,"fontFamily":3},{"id":"t-step2-v3","type":"text","x":355,"y":455,"strokeColor":"#e03131","text":"❷ User Agg's VAD detects speech.\nPushes InterruptionTaskFrame always\n(if bot was idle, queues are empty\n → interruption is a harmless no-op)","fontSize":11,"fontFamily":2},{"id":"a-int-up1","type":"arrow","x":410,"y":520,"strokeColor":"#e8590c","strokeWidth":2,"points":[[0,0],[-142,0]],"endArrowhead":"arrow"},{"id":"t-int-up1","type":"text","x":270,"y":503,"strokeColor":"#e8590c","text":"InterruptionTaskFrame  UPSTREAM ←","fontSize":10,"fontFamily":3},{"id":"a-int-up2","type":"arrow","x":260,"y":530,"strokeColor":"#e8590c","strokeWidth":2,"points":[[0,0],[-142,0]],"endArrowhead":"arrow"},{"id":"t-int-up2","type":"text","x":120,"y":513,"strokeColor":"#e8590c","text":"UPSTREAM ←  (SystemFrame, jumps queue)","fontSize":10,"fontFamily":3},{"id":"t-step3","type":"text","x":42,"y":545,"strokeColor":"#e8590c","text":"❸ Escapes PipelineSource\n   → reaches TaskSource","fontSize":11,"fontFamily":2},{"id":"a-escape","type":"arrow","x":110,"y":555,"strokeColor":"#e8590c","strokeWidth":2,"points":[[0,0],[902,0]],"endArrowhead":"arrow"},{"id":"phase3-bg","type":"rectangle","x":30,"y":595,"width":1240,"height":520,"backgroundColor":"#fff3bf","strokeColor":"#f08c00","strokeStyle":"dashed","roughness":1,"opacity":12},{"id":"phase3-label","type":"text","x":40,"y":600,"strokeColor":"#e8590c","text":"INTERRUPTION: TaskSource injects InterruptionFrame DIRECTLY into pipeline (bypasses _push_queue)","fontSize":14,"fontFamily":2},{"id":"t-step4","type":"text","x":965,"y":625,"strokeColor":"#7048e8","text":"❹ TaskSource catches it.\nCreates InterruptionFrame.\nInjects DIRECTLY into\npipeline.queue_frame()\n(NOT via _push_queue!)","fontSize":11,"fontFamily":2},{"id":"a-int-d1","type":"arrow","x":1020,"y":720,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-175,0]],"endArrowhead":"arrow"},{"id":"t-int-d1","type":"text","x":850,"y":703,"strokeColor":"#e03131","text":"InterruptionFrame  →  DOWNSTREAM","fontSize":10,"fontFamily":3},{"id":"a-int-d2","type":"arrow","x":845,"y":740,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-155,0]],"endArrowhead":"arrow"},{"id":"t-int-d2","type":"text","x":695,"y":723,"strokeColor":"#e03131","text":"→  DOWNSTREAM (SystemFrame)","fontSize":10,"fontFamily":3},{"id":"a-int-d3","type":"arrow","x":690,"y":760,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-130,0]],"endArrowhead":"arrow"},{"id":"t-int-d3","type":"text","x":565,"y":743,"strokeColor":"#e03131","text":"→  DOWNSTREAM","fontSize":10,"fontFamily":3},{"id":"a-int-d4","type":"arrow","x":560,"y":780,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-150,0]],"endArrowhead":"arrow"},{"id":"a-int-d5","type":"arrow","x":410,"y":800,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-150,0]],"endArrowhead":"arrow"},{"id":"a-int-d6","type":"arrow","x":260,"y":820,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[-150,0]],"endArrowhead":"arrow"},{"id":"t-remaining","type":"text","x":42,"y":833,"strokeColor":"#e03131","text":"→ through remaining processors...","fontSize":10,"fontFamily":3},{"id":"a-int-sink","type":"arrow","x":110,"y":850,"strokeColor":"#e03131","strokeWidth":2,"points":[[0,0],[1072,0]],"endArrowhead":"arrow"},{"id":"t-int-sink","type":"text","x":500,"y":855,"strokeColor":"#e03131","text":"→ exits pipeline downstream → reaches TaskSink","fontSize":10,"fontFamily":3},{"id":"t-step5","type":"text","x":690,"y":900,"strokeColor":"#c92a2a","text":"❺ At EACH processor along the way:\n   1. InterruptionFrame enters Input Queue (HIGH priority — jumps ahead)\n   2. Input Task calls _start_interruption()\n   3. Process Task is CANCELLED\n   4. Process Queue is DRAINED:\n        • TTSAudioRawFrame #9, #10  →  DROPPED\n        • LLMTextFrame tokens       →  DROPPED\n        • EndFrame (if any)         →  KEPT (UninterruptibleFrame)\n   5. Fresh Process Task created → processor is clean","fontSize":11,"fontFamily":2},{"id":"t-step6","type":"text","x":1130,"y":960,"strokeColor":"#7048e8","text":"❻ TaskSink calls\nframe.complete()\n(unblocks waiter)","fontSize":11,"fontFamily":2},{"id":"phase4-bg","type":"rectangle","x":30,"y":1130,"width":1240,"height":160,"backgroundColor":"#b2f2bb","strokeColor":"#2f9e44","strokeStyle":"dashed","roughness":1,"opacity":12},{"id":"phase4-label","type":"text","x":40,"y":1135,"strokeColor":"#2f9e44","text":"AFTER: Pipeline is clean. New user turn begins normally.","fontSize":14,"fontFamily":2},{"id":"t-after","type":"text","x":42,"y":1160,"strokeColor":"#2f9e44","text":"Bot is silent. All pending audio chunks are gone.\nThe user's new audio (\"Wait, actually—\") is already\nflowing through STT for the next turn.","fontSize":12,"fontFamily":2},{"id":"a-new-audio","type":"arrow","x":110,"y":1220,"strokeColor":"#2f9e44","points":[[0,0],[142,0]],"endArrowhead":"arrow"},{"id":"t-new-audio","type":"text","x":115,"y":1203,"strokeColor":"#2f9e44","text":"InputAudioRawFrame (new speech)","fontSize":10,"fontFamily":3},{"id":"a-new-trans","type":"arrow","x":260,"y":1240,"strokeColor":"#2f9e44","points":[[0,0],[142,0]],"endArrowhead":"arrow"},{"id":"t-new-trans","type":"text","x":265,"y":1223,"strokeColor":"#2f9e44","text":"TranscriptionFrame(\"Wait, actually...\")","fontSize":10,"fontFamily":3},{"id":"a-new-llm","type":"arrow","x":410,"y":1260,"strokeColor":"#2f9e44","points":[[0,0],[142,0]],"endArrowhead":"arrow"},{"id":"t-new-llm","type":"text","x":415,"y":1243,"strokeColor":"#2f9e44","text":"LLMRunFrame (new context)","fontSize":10,"fontFamily":3},{"id":"t-resumes","type":"text","x":570,"y":1250,"strokeColor":"#868e96","text":"→  normal flow resumes from here...","fontSize":11,"fontFamily":2},{"id":"legend","type":"text","x":50,"y":1320,"strokeColor":"#868e96","text":"Color key:   BLUE = normal data flow (before)     RED = interruption trigger (upstream)     ORANGE/YELLOW = interruption propagation (downstream)     GREEN = recovery (new turn)","fontSize":12,"fontFamily":2},{"id":"latency-note","type":"text","x":50,"y":1345,"strokeColor":"#868e96","text":"Total interruption latency: ~1ms.  SystemFrames jump every priority queue, so the bot stops speaking almost instantly.","fontSize":12,"fontFamily":2}],"appState":{"viewBackgroundColor":"#ffffff","gridSize":null}}